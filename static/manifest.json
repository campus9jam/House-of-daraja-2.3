{
  "name": "House of Daraja",
  "short_name": "HD",
  "description": "Luxury African cultural commerce — fashion, heritage, auctions & bespoke tailoring",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#050505",
  "theme_color": "#050505",
  "lang": "en",
  "dir": "ltr",
  "scope": "/",
  "id": "/",
  "categories": ["shopping", "lifestyle", "fashion"],
  "screenshots": [
    {
      "src": "/hd-logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "House of Daraja Home"
    }
  ],
  "icons": [
    { "src": "/hd-logo.png",     "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/hd-logo.png",     "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/leema-icon.png",  "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "shortcuts": [
    {
      "name": "Shop Now",
      "short_name": "Shop",
      "description": "Browse the HD collection",
      "url": "/shop",
      "icons": [{ "src": "/hd-logo.png", "sizes": "96x96" }]
    },
    {
      "name": "Bespoke Atelier",
      "short_name": "Atelier",
      "description": "Commission a bespoke piece",
      "url": "/atelier",
      "icons": [{ "src": "/hd-logo.png", "sizes": "96x96" }]
    },
    {
      "name": "Live Auction",
      "short_name": "Auction",
      "description": "Bid on rare cultural artifacts",
      "url": "/auction",
      "icons": [{ "src": "/hd-logo.png", "sizes": "96x96" }]
    },
    {
      "name": "Limited Drops",
      "short_name": "Drops",
      "description": "Exclusive limited releases",
      "url": "/drops",
      "icons": [{ "src": "/hd-logo.png", "sizes": "96x96" }]
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [],
  "protocol_handlers": [],
  "share_target": {
    "action": "/shop",
    "method": "GET",
    "params": { "title": "name", "text": "description", "url": "url" }
  }
}
